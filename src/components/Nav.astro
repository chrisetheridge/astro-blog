---
import PaintDrips from "./PaintDrips.astro";
const currentPath = Astro.url.pathname;
---

<div>
  <PaintDrips id="nav-drips" height="12rem" />
  <header class="nav">
    <div class="nav-content">
      <a href="/" class="nav-brand">chrisetheridge</a>
      <div class="nav-links">
        <a
          href="/tags"
          class:list={[{ active: currentPath.startsWith("/tags") }]}>Tags</a
        >
        <a
          href="/search"
          class:list={[
            { active: currentPath === "/search" || currentPath === "/search/" },
          ]}>Search</a
        >
        <a
          href="/about"
          class:list={[
            { active: currentPath === "/about" || currentPath === "/about/" },
          ]}>About</a
        >
        <a href="/rss.xml">RSS</a>
      </div>
    </div>
  </header>
</div>
<style>
  .nav {
    position: relative;
    isolation: isolate;
    padding: var(--space-lg) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-2xl);
  }

  .nav-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-lg);
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text);
  }

  .nav-brand:hover {
    color: var(--color-text-secondary);
  }

  .nav-links {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .nav-links a {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text);
  }
</style>
