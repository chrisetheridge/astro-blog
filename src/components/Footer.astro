---
import PaintDrips from "./PaintDrips.astro";
const year = new Date().getFullYear();
---

<div>
  <footer class="footer">
    <p>&copy; {year} Chris Etheridge. All rights reserved.</p>
  </footer>
  <PaintDrips id="footer-drips" height="180px" fadeTop />
</div>
<style>
  .footer {
    position: relative;
    overflow: visible;
    isolation: isolate;
    margin-top: var(--space-2xl);
    padding: var(--space-lg) var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .footer p {
    position: relative;
    z-index: 1;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }
</style>
