---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="About — Chris Etheridge's Blog" description="About Chris Etheridge's Blog.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "About Chris Etheridge's Blog",
    "description": "About Chris Etheridge's Blog.",
    "url": new URL("/about", Astro.site).href,
    "isPartOf": {
      "@type": "WebSite",
      "name": "Chris Etheridge's Blog",
      "url": Astro.site?.href,
    },
  })} />
  <section class="about">
    <Heading as="h1">About</Heading>
    <Prose>
      <ul>
        <li><a href="https://www.linkedin.com/in/chris-etheridge-b7b59093/">LinkedIn</a></li>
        <li><a href="https://github.com/chrisetheridge">GitHub</a></li>
        <li><a href="mailto:chrismetheridge@gmail.com">Email</a></li>
      </ul>
    </Prose>
  </section>
</Layout>

<style>
  .about {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 1em;
  }
</style>
